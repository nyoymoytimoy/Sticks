# This is a reference template. The actual file Next.js loads is
# frontend/.env.local — copy this there. `backend`'s migration scripts read
# the same file via `--envPath ../frontend/.env.local` (see backend/package.json),
# so there is a single source of truth, not one env file per workspace.

# PostgreSQL connection. Local dev runs its own Postgres container on 5433
# (not 5432) to avoid colliding with other projects' local Postgres instances:
#   docker run -d --name sticks-postgres -e POSTGRES_USER=sticks \
#     -e POSTGRES_PASSWORD=sticks_dev_password -e POSTGRES_DB=sticks \
#     -p 5433:5432 postgres:16-alpine
DATABASE_URL=postgres://sticks:sticks_dev_password@localhost:5433/sticks

# next-auth (added in spec 004)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-generated-secret
