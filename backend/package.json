{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "migrate:up": "node-pg-migrate up --envPath ../frontend/.env.local",
    "migrate:down": "node-pg-migrate down --envPath ../frontend/.env.local",
    "migrate:create": "node-pg-migrate create --migration-file-language sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "node-pg-migrate": "^8.0.4",
    "typescript": "^5"
  }
}
